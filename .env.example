# Claw — A股投顾自动化助手 环境变量
# 复制为 .env 后填入实际值

# ─── 行情数据源 ──────────────────────────────────
# 通达信连接器 (TDX) — 免费实时行情
# TDX_CONNECTOR_URL=http://localhost:8080

# AKShare — 免费金融数据接口 (无需token)
# 已内置，无需额外配置

# ─── AI 分析 ────────────────────────────────────
# DeepSeek API (用于多智能体分析)
# 获取: https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-your_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ─── 飞书通知 ──────────────────────────────────
# 飞书群机器人 Webhook (报告推送、告警通知)
# 获取: 飞书群 → 设置 → 群机器人 → 添加自定义机器人
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# 飞书群聊 Chat ID (用于 lark-cli 发送消息和事件监听)
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── MiniQMT 实盘接口 ─────────────────────────
# MiniQMT API 密钥 (仅实盘交易时需要)
# 获取: MiniQMT客户端 → 系统设置 → API管理
# MINIQMT_API_KEY=your_miniqmt_api_key
# MINIQMT_API_SECRET=your_miniqmt_api_key

# ─── 模拟交易 ──────────────────────────────────
# 模拟交易初始资金 (元)
# SIM_INITIAL_CAPITAL=15000
# 单笔最大仓位比例 (0-1)
# SIM_MAX_POSITION_RATIO=0.3
# 止损比例 (0-1)
# SIM_STOP_LOSS_RATIO=0.05

# ─── 微信读书 ─────────────────────────────────
# 微信读书 Cookie (用于抓取投资文章)
# WEREAD_COOKIE=your_cookie_here
